# Sample app for platform testing: listens on 8080 (required by the orchestrator Deployment).
FROM alpine:3.19
RUN apk add --no-cache busybox-extras
WORKDIR /srv
RUN echo '<!DOCTYPE html><html><body><h1>Hello from go-vercel-app</h1></body></html>' > index.html
EXPOSE 8080
CMD ["httpd", "-f", "-p", "8080", "-h", "/srv"]
