# =============================================================================
# Orchestrator (deploy/) — copy to vars.env and replace placeholders.
# Loaded by: godotenv from ./vars.env when running ./bin/deploy from deploy/
# =============================================================================

# -----------------------------------------------------------------------------
# HTTP server
# -----------------------------------------------------------------------------
# Listen address for POST /deploy-app and POST /build-deploy (NDJSON streaming).
ADDR=:8081

# Optional: if set, callers must send header X-Orchestrator-Secret with the same value.
# Vercel must set ORCHESTRATOR_SHARED_SECRET to match.
ORCHESTRATOR_SHARED_SECRET=ORCHESTRATOR_SECRET

# -----------------------------------------------------------------------------
# Kubernetes (client-go)
# -----------------------------------------------------------------------------
# Namespace where Kaniko Jobs, Deployments, Services, Ingresses, and harbor-regcred
# Secret are created. Must exist before running (kubectl apply deploy/k8s/namespace.yaml).
K8S_NAMESPACE=user-apps

# Path to kubeconfig when running the orchestrator OUTSIDE the cluster (laptop, CI).
# If unset: tries in-cluster config, then ~/.kube/config
KUBECONFIG=/hackthon-kube-config/config

# -----------------------------------------------------------------------------
# Harbor (container registry)
# -----------------------------------------------------------------------------
# Registry hostname only — no https:// (e.g. harbor.example.com or core.harbor.domain:443 if needed).
HARBOR_REGISTRY=git.neev.work

# Harbor project name (must exist in Harbor; images go to registry/project/projectID:tag).
HARBOR_PROJECT=hackthon

# Robot account or user with push + pull to this project.
# Quote if your username contains $ (e.g. Harbor robot names).
HARBOR_USERNAME=admin
HARBOR_PASSWORD=neev@1234$#@!

# Set true if Harbor uses a self-signed CA (adds Kaniko --skip-tls-verify for push).
ORCHESTRATOR_SKIP_HARBOR_TLS_VERIFY=false

# -----------------------------------------------------------------------------
# Ingress / Gateway API (user-facing URL)
# -----------------------------------------------------------------------------
# Public hostname suffix. With prefix "svc", host is svc-{projectID}.{INGRESS_BASE_DOMAIN} (HTTPRoute name svc-{projectID}).
# Without prefix: {projectID}.{INGRESS_BASE_DOMAIN}. DNS must resolve to your ingress or Gateway LB.
# Do not duplicate INGRESS_BASE_DOMAIN — godotenv uses the first assignment only.
INGRESS_BASE_DOMAIN=launchpad.neev.work
PUBLIC_HOST_SUBDOMAIN_PREFIX=svc

# Ingress class name (e.g. nginx). Leave empty if unused (Gateway-only clusters).
INGRESS_CLASS_NAME=nginx

# Gateway API (Istio) — set GATEWAY_NAME to create HTTPRoute instead of Ingress.
GATEWAY_NAMESPACE=istio-system
GATEWAY_NAME=istio-public-gateway
GATEWAY_SECTION_NAME=http

# Optional: TLS secret name in K8S_NAMESPACE (same namespace as Ingress).
# Leave empty for HTTP-only (PublicURL will still use https if this is set in code).
INGRESS_TLS_SECRET_NAME=

# -----------------------------------------------------------------------------
# Build / runtime
# -----------------------------------------------------------------------------
# Kaniko executor image (cluster must pull from gcr.io or mirror it).
KANIKO_IMAGE=gcr.io/kaniko-project/executor:v1.23.2

# Default Dockerfile path in the Git repo (Kaniko --dockerfile) when POST /deploy-app omits "dockerfile".
KANIKO_DOCKERFILE=Dockerfile

# Max bytes for JSON field "dockerfileContent" (inline Dockerfile). Default 524288; cap 1048576.
# MAX_DOCKERFILE_CONTENT_BYTES=524288

# Container port your app Dockerfile must listen on (Deployment container port / Service targetPort).
APP_CONTAINER_PORT=8080

# Port exposed on the Kubernetes Service (ClusterIP). Ingress and HTTPRoute backendRefs use this.
# Default 80. Example: set 8080 if you want Service :8080 -> pod targetPort APP_CONTAINER_PORT.
K8S_SERVICE_PORT=80

# Max time to wait for Kaniko Job success (seconds). Also sets Job activeDeadlineSeconds.
BUILD_JOB_TIMEOUT_SEC=1800

# Default Git ref when the client does not send gitRef (Kaniko --context git://...#ref).
DEFAULT_GIT_REF=refs/heads/main
