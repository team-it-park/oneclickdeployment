# =============================================================================
# Orchestrator (deploy/) — copy to vars.env and replace placeholders.
# Loaded by: godotenv from ./vars.env when running ./bin/deploy from deploy/
# =============================================================================

# -----------------------------------------------------------------------------
# HTTP server
# -----------------------------------------------------------------------------
# Listen address for POST /build-deploy (NDJSON streaming).
ADDR=:8081

# Optional: if set, callers must send header X-Orchestrator-Secret with the same value.
# Vercel must set ORCHESTRATOR_SHARED_SECRET to match.
ORCHESTRATOR_SHARED_SECRET=CHANGE_ME_ORCHESTRATOR_SECRET

# -----------------------------------------------------------------------------
# Kubernetes (client-go)
# -----------------------------------------------------------------------------
# Namespace where Kaniko Jobs, Deployments, Services, Ingresses, and harbor-regcred
# Secret are created. Must exist before running (kubectl apply deploy/k8s/namespace.yaml).
K8S_NAMESPACE=user-apps

# Path to kubeconfig when running the orchestrator OUTSIDE the cluster (laptop, CI).
# If unset: tries in-cluster config, then ~/.kube/config
# KUBECONFIG=/root/.kube/config

# -----------------------------------------------------------------------------
# Harbor (container registry)
# -----------------------------------------------------------------------------
# Registry hostname only — no https:// (e.g. harbor.example.com or core.harbor.domain:443 if needed).
HARBOR_REGISTRY=harbor.example.com

# Harbor project name (must exist in Harbor; images go to registry/project/projectID:tag).
HARBOR_PROJECT=go-vercel-apps

# Robot account or user with push + pull to this project.
HARBOR_USERNAME="robot$go-vercel-apps+deploy"
HARBOR_PASSWORD=CHANGE_ME_HARBOR_TOKEN

# Set true if Harbor uses a self-signed CA (adds Kaniko --skip-tls-verify for push).
ORCHESTRATOR_SKIP_HARBOR_TLS_VERIFY=false

# -----------------------------------------------------------------------------
# Ingress (user-facing URL)
# -----------------------------------------------------------------------------
# Public hostname suffix: deployed apps get https://{projectID}.{INGRESS_BASE_DOMAIN}
# DNS must resolve *.INGRESS_BASE_DOMAIN to your ingress load balancer.
INGRESS_BASE_DOMAIN=apps.example.com

# Ingress class name (e.g. nginx for ingress-nginx). Leave empty if your controller does not use it.
INGRESS_CLASS_NAME=nginx

# Optional: TLS secret name in K8S_NAMESPACE (same namespace as Ingress). Wildcard cert for *.apps.example.com.
# Leave empty for HTTP-only (PublicURL will still use https if this is set in code).
INGRESS_TLS_SECRET_NAME=

# -----------------------------------------------------------------------------
# Build / runtime
# -----------------------------------------------------------------------------
# Kaniko executor image (cluster must pull from gcr.io or mirror it).
KANIKO_IMAGE=gcr.io/kaniko-project/executor:v1.23.2

# Container port your app Dockerfile must listen on (Deployment/Service target this).
APP_CONTAINER_PORT=8080

# Max time to wait for Kaniko Job success (seconds). Also sets Job activeDeadlineSeconds.
BUILD_JOB_TIMEOUT_SEC=1800

# Default Git ref when the client does not send gitRef (Kaniko --context git://...#ref).
DEFAULT_GIT_REF=refs/heads/main
