# =============================================================================
# Vercel web app (vercel/) — copy to vars.env and replace placeholders.
# Loaded by: godotenv from ./vars.env when running ./bin/vercel from vercel/
# =============================================================================

# -----------------------------------------------------------------------------
# HTTP server
# -----------------------------------------------------------------------------
ADDR=:8080

# When behind nginx/Istio TLS, set to the public origin (scheme + host, no path). Enables GitHub OAuth and correct redirects.
# Example: https://app.launchpad.neev.work
APP_PUBLIC_ORIGIN=

# Set true when the app runs behind a reverse proxy that sets X-Forwarded-For (nginx → Istio → pod).
TRUST_PROXY=false

# Session cookie encryption key (long random string; do not commit real secrets to git).
SECRET=CHANGE_ME_GENERATE_32_RANDOM_BYTES

# -----------------------------------------------------------------------------
# PostgreSQL (GORM)
# -----------------------------------------------------------------------------
# DSN examples:
#   postgres://user:password@localhost:5432/go_vercel?sslmode=disable
#   host=127.0.0.1 user=postgres password=secret dbname=go_vercel port=5432 sslmode=disable
DBADDRESS=postgres://postgres:CHANGE_ME@localhost:5432/go_vercel?sslmode=disable

# Apply schema once: psql "$DBADDRESS" -f db.sql (or equivalent).

# -----------------------------------------------------------------------------
# Orchestrator (deploy service)
# -----------------------------------------------------------------------------
# Base URL of the deploy orchestrator (no trailing slash).
# Local: http://127.0.0.1:8081  Same Docker network: http://deploy:8081
ORCHESTRATOR_ADDR=http://127.0.0.1:8081

# Path for user app deploy (default /deploy-app). Use /build-deploy only for legacy.
# ORCHESTRATOR_DEPLOY_PATH=/deploy-app

# Must match deploy ORCHESTRATOR_SHARED_SECRET if that is set.
ORCHESTRATOR_SHARED_SECRET=CHANGE_ME_ORCHESTRATOR_SECRET

# Optional: Git ref passed to POST /build-deploy (e.g. refs/heads/main). Empty = orchestrator default.
ORCHESTRATOR_DEFAULT_GIT_REF=

# Optional: HTTP client timeout for the long deploy call (minutes). Default 45.
ORCHESTRATOR_HTTP_TIMEOUT_MINUTES=45

# (GitHub OAuth + email SMTP were previously here; LaunchPad now uses simple
# email+password auth only, so no extra provider configuration is required.)
